// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EmployeeRole {
  ADMIN
  STAFF
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
}

enum WageType {
  EMPLOYEE
  JOB_FIXED
}

enum UnavailableType {
  FULL_DAY
  TIME_RANGE
  WEEKLY_FIXED
  TEMPORARY
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ShiftAssignmentStatus {
  ASSIGNED
  CANCELED
}

enum ExternalStaffAssignmentStatus {
  ASSIGNED
  CANCELED
}

enum WorkReportStatus {
  NOT_SUBMITTED
  SUBMITTED
  APPROVED
  REJECTED
}

model Employee {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  passwordHash     String?
  role             EmployeeRole     @default(STAFF)
  hourlyWage       Int
  startedWorkingAt DateTime
  employmentStatus EmploymentStatus @default(ACTIVE)

  unavailableTimes UnavailableTime[]
  shiftAssignments ShiftAssignment[]
  workReports      WorkReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, employmentStatus])
  @@index([employmentStatus, startedWorkingAt])
}

model Job {
  id                String   @id @default(cuid())
  title             String
  workDate          DateTime
  location          String
  meetingPlace      String?
  breakMinutes      Int      @default(0)
  hasMeal           Boolean  @default(false)
  transportationFee Int      @default(0)
  dressCode         String?
  belongings        String?
  note              String?
  wageType          WageType @default(EMPLOYEE)
  fixedHourlyWage   Int?

  shiftSlots  JobShiftSlot[]
  workReports WorkReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workDate])
}

model JobTemplate {
  id                String   @id @default(cuid())
  name              String
  title             String
  location          String
  meetingPlace      String?
  breakMinutes      Int      @default(0)
  hasMeal           Boolean  @default(false)
  transportationFee Int      @default(0)
  dressCode         String?
  belongings        String?
  note              String?
  wageType          WageType @default(EMPLOYEE)
  fixedHourlyWage   Int?

  shiftSlots JobTemplateShiftSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobTemplateShiftSlot {
  id             String @id @default(cuid())
  jobTemplateId  String
  name           String
  startTime      String
  endTime        String
  requiredPeople Int

  jobTemplate JobTemplate @relation(fields: [jobTemplateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobTemplateId])
}

model JobShiftSlot {
  id             String @id @default(cuid())
  jobId          String
  name           String
  startTime      String
  endTime        String
  startTimeMinutes Int
  endTimeMinutes   Int
  requiredPeople Int

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  shiftAssignments         ShiftAssignment[]
  externalStaffAssignments ExternalStaffAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([jobId, startTime])
  @@index([jobId, startTimeMinutes])
}

model ShiftAssignment {
  id         String                @id @default(cuid())
  slotId     String
  employeeId String
  status     ShiftAssignmentStatus @default(ASSIGNED)

  slot     JobShiftSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slotId, employeeId])
  @@index([slotId])
  @@index([employeeId])
  @@index([slotId, status])
  @@index([employeeId, status])
}

model ExternalStaffAssignment {
  id String @id @default(cuid())

  slotId String
  slot   JobShiftSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  name      String
  headCount Int    @default(1)

  status ExternalStaffAssignmentStatus @default(ASSIGNED)
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slotId])
  @@index([slotId, status])
}

model UnavailableTime {
  id         String          @id @default(cuid())
  employeeId String
  type       UnavailableType
  date       DateTime?
  dayOfWeek  DayOfWeek?
  startTime  String?
  endTime    String?
  reason     String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([employeeId, date])
  @@index([employeeId, dayOfWeek])
}

model WorkReport {
  id                 String           @id @default(cuid())
  jobId              String
  employeeId         String
  actualStartTime    String
  actualEndTime      String
  actualBreakMinutes Int
  transportationFee  Int
  hasMeal            Boolean          @default(false)
  status             WorkReportStatus @default(NOT_SUBMITTED)

  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, employeeId])
  @@index([jobId])
  @@index([employeeId])
  @@index([jobId, status])
  @@index([employeeId, status])
}
